              "x-bentoml-name": "update_config",
              "description": "Update camera configuration (supports partial updates)\n        \n        Supports partial updates - only specified fields are updated.\n        Can update individual camera settings or global NATS settings.\n        \n        Pipeline restart logic:\n        - Full restart required for: uri, output_uri, motioncells settings (except gap, postnomotion)\n        - Soft update (no restart) for: motioncells.gap, motioncells.postnomotion, core_targets, debug settings (display, debug_duration)\n        \n        Note: All motioncells settings require pipeline restart except 'gap' and 'postnomotion',\n        which are used only by Python code in _dispatch_commands.\n        ",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "title": "Input",
                      "required": [
                        "data"
                      ],
                      "properties": {
                        "data": {
                          "additionalProperties": true,
                          "title": "Data",
                          "type": "object"
                        }
                      }
                    }
                  }
                }
              },
              "operationId": "motion-detector__update_config"
            }
          },
