    {
      "name": "add_cron_job",
      "host_count": 66,
      "descriptions": [
        "Schedule a new cron job"
      ],
      "schemas": [
        {
          "type": "object",
          "properties": {
            "scheduleName": {
              "type": "string",
              "description": "Unique identifier for the job"
            },
            "scheduleExpression": {
              "type": "string",
              "description": "Cron expression (e.g., '0 9 * * *' for daily at 9am)"
            },
            "command": {
              "type": "string",
              "description": "The command or prompt to run"
            },
            "timezone": {
              "type": "string",
              "description": "IANA timezone (e.g., 'America/New_York')"
            }
          },
          "required": [
            "scheduleName",
            "scheduleExpression",
            "command"
          ]
        }
      ]
    },
