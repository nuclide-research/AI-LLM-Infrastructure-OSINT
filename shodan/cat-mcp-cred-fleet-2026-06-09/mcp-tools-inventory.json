      ],
      "schemas": [
        {
          "type": "object",
          "properties": {
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of shell commands to queue for asynchronous execution"
            }
          },
          "required": [
            "commands"
          ]
        }
      ]
